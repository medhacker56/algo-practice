{
  "name": "algo-practice",
  "version": "1.0.0",
  "private": true,
  "description": "Algo Practice — simple full-stack app for algorithm practice tasks with auth and CRUD using Next.js, Prisma and Postgres.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint --ext .js,.jsx .",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "node prisma/seed.js"
  },
  "author": "Algo Practice",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^4.16.0",
    "bcryptjs": "^2.4.3",
    "cookie": "^0.5.0",
    "jsonwebtoken": "^9.0.0",
    "next": "13.4.20",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "swr": "^2.2.0"
  },
  "devDependencies": {
    "prisma": "^4.16.0",
    "tailwindcss": "^3.4.8",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24",
    "eslint": "^8.47.0",
    "prettier": "^3.0.0"
  }
}
